    {
      "id": "fvbl-summer-doubles-rc-jul-2026",
      "source": "fvbl",
      "sourceUrl": "https://www.facebook.com/events/1255850129994276/",
      "name": "Summer Doubles Rev Co",
      "startDate": "2026-07-18",
      "location": {
        "city": "Bay Area",
        "state": "CA"
      },
      "divisions": [
        "Reverse Coed"
      ],
      "registrationUrl": "http://bit.ly/fvbl-2s-rc-rsvp-2",
      "format": "2s",
      "surface": "grass",
      "description": "Summer Doubles Reverse Coed — a Saturday grass 2s tournament from FVBL (@fvbleague), running out of the Newark/Fremont grass scene in the Bay Area. Sign up via the bit.ly form; that's the official RSVP, not the FB event. Reverse Coed means the women drive the offense and the net is at women's height: men can only attack from behind the 10-foot line, and if a man contacts the ball above net height at or in front of the line it must travel upward (no driving it down). Men cannot block — any blocking contact above the net is an automatic side out. Women have no front-row restrictions. Standard FVBL 2s rules apply: shorter court, no open-hand passing on serve receive or rallies, set-overs square only, one timeout per set, BYO whistle for reffing and BYO ball/shade/water."
    },
    {
      "id": "fvbl-summer-doubles-mw-jul-2026",
      "source": "fvbl",
      "sourceUrl": "https://www.facebook.com/events/26221887760766283/",
